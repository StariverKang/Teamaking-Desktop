generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppVersion {
  id                String    @id @default(cuid())
  name              String
  phase             String    @default("testing")
  status            String    @default("active")
  notes             String?
  startedAt         DateTime  @default(now())
  endedAt           DateTime?
  createdByUserId   String?
  finalCheckpointId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  users              User[]
  emailVerifications EmailVerification[]
  schools            School[]
  importBatches      CourseImportBatch[]
  importDatasets     CourseImportDataset[]
  checkpoints        VersionCheckpoint[]
  operationLogs      OperationLog[]
  auditLogs          AdminAuditLog[]
  crawlerJobs        CrawlerJob[]
  errorEvents        ErrorEvent[]
  authEvents         AuthEvent[]
  announcements      SiteAnnouncement[]
  contentDocuments   ContentDocument[]

  @@index([status])
  @@index([phase])
}

model User {
  id                  String    @id @default(cuid())
  appVersionId        String    @default("legacy")
  email               String
  schoolId            String?
  role                String    @default("verified_user")
  passwordHash        String?
  status              String    @default("active")
  suspendedUntil      DateTime?
  adminNote           String?
  isEmailVerified     Boolean   @default(false)
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  appVersion             AppVersion              @relation(fields: [appVersionId], references: [id])
  school                 School?                 @relation(fields: [schoolId], references: [id])
  profile                UserProfile?
  contactInfo            ContactInfo?
  skills                 UserSkill[]
  memberships            CourseBoardMembership[]
  submittedCourses       UserSubmittedCourse[]
  teamakingPosts         TeamakingPost[]
  sentTeamUpRequests     TeamUpRequest[]         @relation("SentTeamUpRequests")
  receivedRequests       TeamUpRequest[]         @relation("ReceivedTeamUpRequests")
  sentFollowRequests     FollowRequest[]         @relation("SentFollowRequests")
  receivedFollowRequests FollowRequest[]         @relation("ReceivedFollowRequests")
  portfolioItems         PortfolioItem[]
  endorsementsGiven      Endorsement[]           @relation("EndorsementsGiven")
  endorsementsGot        Endorsement[]           @relation("EndorsementsGot")
  boardSectionsCreated   CourseBoardSection[]
  auditLogs              AdminAuditLog[]
  operationLogs          OperationLog[]
  errorEvents            ErrorEvent[]
  supportTickets         SupportTicket[]
  announcementReads      UserAnnouncementRead[]
  publishedAnnouncements SiteAnnouncement[]      @relation("AnnouncementPublisher")
  courseReviewComments   CourseReviewComment[]

  @@unique([appVersionId, email])
  @@index([appVersionId])
  @@index([schoolId])
}

model EmailVerification {
  id           String    @id @default(cuid())
  appVersionId String    @default("legacy")
  email        String
  code         String
  purpose      String    @default("login")
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  appVersion AppVersion @relation(fields: [appVersionId], references: [id])

  @@index([appVersionId])
  @@index([email])
  @@index([email, purpose])
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  displayName        String
  nickname           String?
  avatarUrl          String?
  backgroundImageUrl String?
  headline           String?
  bio                String   @default("")
  grade              String?
  entryYear          Int?
  entryTerm          String?
  facultyId          String?
  majorId            String?
  outputTags         Json     @default("[]")
  resumeUrl          String?
  resumeFileName     String?
  resumeParsedData   Json     @default("{}")
  openToBeDiscovered Boolean  @default(true)
  visibilitySettings Json     @default("{}")
  onboardingTourDismissedAt DateTime?
  academicOverrideReason    String?
  academicOverrideByUserId  String?
  academicOverrideAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  faculty Faculty? @relation(fields: [facultyId], references: [id])
  major   Major?   @relation(fields: [majorId], references: [id])

  @@index([majorId])
  @@index([entryYear, entryTerm])
}

model ContactInfo {
  id                 String   @id @default(cuid())
  userId             String   @unique
  schoolEmail        String
  wechatId           String?
  wechatQrImageUrl   String?
  linkedinUrl        String?
  personalEmail      String?
  visibilitySettings Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id           String        @id @default(cuid())
  name         String        @unique
  category     String
  userLinks    UserSkill[]
  endorsements Endorsement[]
}

model UserSkill {
  id           String @id @default(cuid())
  userId       String
  skillId      String
  level        String @default("beginner")
  evidenceNote String @default("")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model School {
  id           String   @id @default(cuid())
  appVersionId String   @default("legacy")
  name         String
  shortName    String
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appVersion     AppVersion            @relation(fields: [appVersionId], references: [id])
  users          User[]
  domains        SchoolEmailDomain[]
  faculties      Faculty[]
  majors         Major[]
  semesters      Semester[]
  courses        Course[]
  submissions    UserSubmittedCourse[]
  importBatches  CourseImportBatch[]
  importDatasets CourseImportDataset[]

  @@unique([appVersionId, shortName])
  @@index([appVersionId])
}

model SchoolEmailDomain {
  id       String @id @default(cuid())
  schoolId String
  domain   String
  status   String @default("active")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, domain])
  @@index([domain])
}

model Faculty {
  id       String  @id @default(cuid())
  schoolId String
  code     String?
  name     String

  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  majors   Major[]
  profiles UserProfile[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
}

model Major {
  id         String  @id @default(cuid())
  schoolId   String
  facultyId  String
  code       String?
  name       String
  degreeType String  @default("undergraduate")

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  faculty  Faculty              @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  profiles UserProfile[]
  mappings CourseMajorMapping[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
}

model Semester {
  id        String  @id @default(cuid())
  schoolId  String
  code      String?
  name      String
  year      Int
  term      String
  isCurrent Boolean @default(false)

  school          School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  offerings       CourseOffering[]
  curriculumRules CourseCurriculumRule[]

  @@unique([schoolId, name])
  @@unique([schoolId, code])
}

model Course {
  id                   String   @id @default(cuid())
  schoolId             String
  code                 String
  title                String
  description          String   @default("")
  credits              Float?
  ownerUnit            Json     @default("{}")
  categoryTags         Json     @default("[]")
  sourceRefIds         Json     @default("[]")
  manualOverrideFields Json     @default("[]")
  manualNote           String?
  courseType           String   @default("coursework")
  status               String   @default("active")
  source               String   @default("admin_seed")
  mergedIntoCourseId   String?
  mergedAt             DateTime?
  mergeNote            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  school          School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  offerings       CourseOffering[]
  mappings        CourseMajorMapping[]
  curriculumRules CourseCurriculumRule[]
  portfolios      PortfolioItem[]
  reviewComments  CourseReviewComment[]

  @@unique([schoolId, code])
  @@index([title])
  @@index([mergedIntoCourseId])
}

model CourseOffering {
  id           String   @id @default(cuid())
  courseId     String
  semesterId   String
  teacherName  String?
  section      String?
  sourceRefIds Json     @default("[]")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course           Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester         Semester                @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  boards           CourseBoard[]
  posts            TeamakingPost[]
  syllabusMetadata CourseSyllabusMetadata?

  @@index([courseId, semesterId])
}

model CourseMajorMapping {
  id                   String  @id @default(cuid())
  courseId             String
  majorId              String
  recommendedGrade     String
  isRequired           Boolean @default(false)
  isDefaultRecommended Boolean @default(true)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  major  Major  @relation(fields: [majorId], references: [id], onDelete: Cascade)

  @@unique([courseId, majorId, recommendedGrade])
}

model CourseBoard {
  id               String    @id @default(cuid())
  courseOfferingId String
  title            String
  status           String    @default("active")
  rules            String    @default("请尊重同学，清楚表达自己的贡献方式，不要把 Course People 误认为官方选课名单。")
  openFrom         DateTime?
  openUntil        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  courseOffering CourseOffering          @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  memberships    CourseBoardMembership[]
  sections       CourseBoardSection[]
  posts          TeamakingPost[]

  @@index([courseOfferingId])
}

model CourseBoardSection {
  id              String   @id @default(cuid())
  boardId         String
  code            String
  source          String   @default("student_created")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  board     CourseBoard             @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy User?                   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  members   CourseBoardMembership[]

  @@unique([boardId, code])
  @@index([code])
}

model CourseBoardMembership {
  id           String    @id @default(cuid())
  userId       String
  boardId      String
  sectionId    String?
  sectionCode  String?
  source       String    @default("manual")
  status       String    @default("active")
  originRuleId String?
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  board   CourseBoard         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  section CourseBoardSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([userId, boardId])
  @@index([status])
  @@index([originRuleId])
  @@index([sectionId])
  @@index([sectionCode])
}

model CourseImportBatch {
  id                String    @id @default(cuid())
  appVersionId      String    @default("legacy")
  datasetId         String?
  schoolId          String?
  name              String?
  schemaVersion     String
  semesterCode      String?
  cohortYears       Json      @default("[]")
  payloadHash       String?
  summary           Json      @default("{}")
  sourceLabel       String?
  status            String    @default("pending")
  payload           Json
  validationSummary Json      @default("{}")
  approvedByUserId  String?
  approvedAt        DateTime?
  rejectedByUserId  String?
  rejectedAt        DateTime?
  adminNote         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  appVersion      AppVersion             @relation(fields: [appVersionId], references: [id])
  dataset         CourseImportDataset?   @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  school          School?                @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  curriculumRules CourseCurriculumRule[]

  @@index([appVersionId])
  @@index([datasetId])
  @@index([schoolId])
  @@index([status])
  @@index([semesterCode])
  @@index([payloadHash])
}

model CourseImportDataset {
  id                  String   @id @default(cuid())
  appVersionId        String   @default("legacy")
  schoolId            String?
  name                String
  schemaVersion       String
  semesterCode        String?
  cohortYears         Json     @default("[]")
  sourceLabel         String?
  payloadHash         String
  status              String   @default("draft")
  summary             Json     @default("{}")
  validationSummary   Json     @default("{}")
  originalFileName    String
  originalStorageKey  String?
  originalSize        Int?
  originalContentType String   @default("application/json")
  createdByUserId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  appVersion AppVersion                     @relation(fields: [appVersionId], references: [id])
  school     School?                        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  batches    CourseImportBatch[]
  sourceRefs CourseImportDatasetSourceRef[]
  faculties  CourseImportDatasetFaculty[]
  majors     CourseImportDatasetMajor[]
  courses    CourseImportDatasetCourse[]
  rules      CourseImportDatasetRule[]
  offerings  CourseImportDatasetOffering[]

  @@index([appVersionId])
  @@index([schoolId])
  @@index([status])
  @@index([payloadHash])
}

model CourseImportDatasetSourceRef {
  id         String  @id @default(cuid())
  datasetId  String
  externalId String
  title      String?
  url        String?
  sourceType String?
  raw        Json    @default("{}")

  dataset CourseImportDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, externalId])
}

model CourseImportDatasetFaculty {
  id        String @id @default(cuid())
  datasetId String
  code      String
  name      String
  raw       Json   @default("{}")

  dataset CourseImportDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, code])
}

model CourseImportDatasetMajor {
  id          String  @id @default(cuid())
  datasetId   String
  code        String
  name        String
  facultyCode String?
  degreeType  String?
  raw         Json    @default("{}")

  dataset CourseImportDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, code])
}

model CourseImportDatasetCourse {
  id           String @id @default(cuid())
  datasetId    String
  code         String
  title        String
  credits      Float?
  categoryTags Json   @default("[]")
  ownerUnit    Json   @default("{}")
  raw          Json   @default("{}")

  dataset CourseImportDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, code])
  @@index([code])
}

model CourseImportDatasetRule {
  id                String @id @default(cuid())
  datasetId         String
  externalId        String
  courseCode        String
  classification    String
  studentAction     String
  audience          Json   @default("{}")
  relativeTermCodes Json   @default("[]")
  sourceRefIds      Json   @default("[]")
  raw               Json   @default("{}")

  dataset CourseImportDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, externalId])
  @@index([courseCode])
  @@index([classification])
}

model CourseImportDatasetOffering {
  id           String  @id @default(cuid())
  datasetId    String
  externalId   String
  courseCode   String
  semesterCode String?
  sections     Json    @default("[]")
  raw          Json    @default("{}")

  dataset CourseImportDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, externalId])
  @@index([courseCode])
}

model CourseCurriculumRule {
  id                  String   @id @default(cuid())
  importBatchId       String?
  externalId          String
  courseId            String
  semesterId          String
  classification      String
  classificationLabel String?
  studentAction       String
  audience            Json     @default("{}")
  relativeTermCodes   Json     @default("[]")
  ownerUnit           Json     @default("{}")
  sourceRefIds        Json     @default("[]")
  confidence          String   @default("unknown")
  status              String   @default("active")
  raw                 Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  importBatch CourseImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semester    Semester           @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([semesterId, externalId])
  @@index([courseId])
  @@index([classification])
  @@index([studentAction])
  @@index([status])
}

model CourseSyllabusMetadata {
  id                   String   @id @default(cuid())
  courseOfferingId     String   @unique
  teamworkRequirement  String   @default("unknown")
  teamworkSummary      String?
  evidenceSourceRefIds Json     @default("[]")
  confidence           String   @default("unknown")
  raw                  Json     @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  courseOffering CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)

  @@index([teamworkRequirement])
}

model CrawlerJob {
  id              String    @id @default(cuid())
  appVersionId    String    @default("legacy")
  name            String
  target          String    @default("programme_handbook")
  status          String    @default("running")
  input           Json      @default("{}")
  command         String?
  logs            Json      @default("[]")
  outputs         Json      @default("[]")
  errorMessage    String?
  exitCode        Int?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appVersion AppVersion @relation(fields: [appVersionId], references: [id], onDelete: Cascade)

  @@index([appVersionId, startedAt])
  @@index([status])
}

model UserSubmittedCourse {
  id                String   @id @default(cuid())
  submittedByUserId String
  schoolId          String
  code              String
  title             String
  teacherName       String?
  semesterText      String?
  status            String   @default("pending")
  adminNote         String?
  matchedCourseId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  submittedBy User   @relation(fields: [submittedByUserId], references: [id], onDelete: Cascade)
  school      School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id                String    @id @default(cuid())
  submittedByUserId String?
  email             String?
  category          String    @default("other")
  title             String
  description       String
  relatedUrl        String?
  status            String    @default("open")
  adminNote         String?
  adminReply        String?
  adminRepliedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  submittedBy User? @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([category])
  @@index([submittedByUserId])
}

model TeamakingPost {
  id                String    @id @default(cuid())
  boardId           String
  userId            String
  courseOfferingId  String
  title             String
  status            String    @default("open")
  strengths         Json      @default("[]")
  contributionTypes Json      @default("[]")
  expectedOutcome   String
  portfolioItemIds  Json      @default("[]")
  showWechatId      Boolean   @default(false)
  showWechatQr      Boolean   @default(false)
  showLinkedin      Boolean   @default(false)
  showPersonalEmail Boolean   @default(false)
  visibility        String    @default("same_course_board")
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  board          CourseBoard     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseOffering CourseOffering  @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  requests       TeamUpRequest[]

  @@index([boardId, status])
  @@index([userId])
}

model TeamUpRequest {
  id                      String   @id @default(cuid())
  postId                  String
  senderId                String
  receiverId              String
  message                 String
  senderContribution      String
  senderContactSnapshot   Json     @default("{}")
  receiverContactSnapshot Json     @default("{}")
  status                  String   @default("sent")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  post     TeamakingPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  sender   User          @relation("SentTeamUpRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User          @relation("ReceivedTeamUpRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([postId, senderId])
  @@index([senderId])
  @@index([receiverId])
}

model FollowRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentFollowRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFollowRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model PortfolioItem {
  id                      String   @id @default(cuid())
  userId                  String
  title                   String
  type                    String
  relatedCourseId         String?
  semesterText            String?
  myRole                  String?
  contributionDescription String
  isGroupWork             Boolean  @default(false)
  fileName                String?
  fileMimeType            String?
  fileSize                Int?
  fileExtension           String?
  storageKey              String?
  storageMode             String?
  storageProvider         String?
  objectKey               String?
  scanStatus              String   @default("not_scanned")
  fileUrl                 String?
  externalUrl             String?
  previewKind             String   @default("link")
  outcome                 String?
  reflection              String?
  parsedText              String?
  metadata                Json     @default("{}")
  visibility              String   @default("same_school")
  isPinned                Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedCourse Course? @relation(fields: [relatedCourseId], references: [id])
}

model Endorsement {
  id                        String   @id @default(cuid())
  fromUserId                String
  toUserId                  String
  skillId                   String
  comment                   String
  willingToCollaborateAgain Boolean  @default(true)
  createdAt                 DateTime @default(now())

  fromUser User  @relation("EndorsementsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User  @relation("EndorsementsGot", fields: [toUserId], references: [id], onDelete: Cascade)
  skill    Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

model CourseReviewComment {
  id             String    @id @default(cuid())
  courseId       String
  userId         String
  parentId       String?
  body           String
  status         String    @default("active")
  deletedAt      DateTime?
  deletedByUserId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  course   Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   CourseReviewComment?  @relation("CourseReviewReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  CourseReviewComment[] @relation("CourseReviewReplies")

  @@index([courseId, parentId, createdAt])
  @@index([userId, createdAt])
  @@index([status])
}

model ErrorEvent {
  id           String   @id @default(cuid())
  appVersionId String   @default("legacy")
  requestId    String   @unique
  errorCode    String
  message      String
  path         String?
  method       String?
  status       Int?
  userId       String?
  actorRole    String?
  stackDigest  String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  appVersion AppVersion @relation(fields: [appVersionId], references: [id])
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([appVersionId, createdAt])
  @@index([errorCode])
  @@index([userId, createdAt])
  @@index([path])
}

model AuthEvent {
  id           String   @id @default(cuid())
  appVersionId String   @default("legacy")
  email        String
  action       String
  purpose      String
  success      Boolean  @default(false)
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  appVersion AppVersion @relation(fields: [appVersionId], references: [id])

  @@index([appVersionId, email, action, purpose, createdAt])
  @@index([action, success, createdAt])
}

model SiteConfig {
  id              String   @id @default(cuid())
  key             String   @unique
  value           Json
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
}

model SiteAnnouncement {
  id                String    @id @default(cuid())
  appVersionId      String    @default("legacy")
  titleZh           String
  titleEn           String?
  bodyZh            String
  bodyEn            String?
  status            String    @default("draft")
  audience          String    @default("all")
  priority          Int       @default(0)
  startsAt          DateTime?
  endsAt            DateTime?
  publishedAt       DateTime?
  publishedByUserId String?
  archivedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  appVersion  AppVersion             @relation(fields: [appVersionId], references: [id], onDelete: Cascade)
  publishedBy User?                  @relation("AnnouncementPublisher", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  reads       UserAnnouncementRead[]

  @@index([appVersionId, status, publishedAt])
  @@index([audience])
}

model ContentDocument {
  id              String    @id @default(cuid())
  appVersionId    String    @default("legacy")
  kind            String
  nodeType        String    @default("document")
  parentId        String?
  slug            String
  title           String
  summary         String?
  bodyMarkdown    String    @default("")
  imageUrls       Json      @default("[]")
  status          String    @default("draft")
  displayOrder    Int       @default(0)
  publishedAt     DateTime?
  updatedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appVersion AppVersion        @relation(fields: [appVersionId], references: [id], onDelete: Cascade)
  parent     ContentDocument?  @relation("ContentDocumentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   ContentDocument[] @relation("ContentDocumentTree")

  @@unique([appVersionId, kind, slug])
  @@index([appVersionId, kind, status])
  @@index([nodeType])
  @@index([parentId])
  @@index([displayOrder])
}

model UserAnnouncementRead {
  id             String    @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime  @default(now())
  dismissedAt    DateTime?

  announcement SiteAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId, readAt])
}

model VersionCheckpoint {
  id                String   @id @default(cuid())
  appVersionId      String
  label             String
  kind              String   @default("operation")
  reason            String?
  triggeredByUserId String?
  summary           Json     @default("{}")
  createdAt         DateTime @default(now())

  appVersion AppVersion               @relation(fields: [appVersionId], references: [id], onDelete: Cascade)
  chunks     VersionCheckpointChunk[]

  @@index([appVersionId])
  @@index([createdAt])
}

model VersionCheckpointChunk {
  id           String @id @default(cuid())
  checkpointId String
  name         String
  rowCount     Int    @default(0)
  data         Json   @default("[]")

  checkpoint VersionCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Cascade)

  @@unique([checkpointId, name])
}

model OperationLog {
  id           String   @id @default(cuid())
  appVersionId String   @default("legacy")
  actorUserId  String?
  actorRole    String?
  action       String
  targetType   String?
  targetId     String?
  method       String?
  path         String?
  status       String   @default("success")
  summary      Json     @default("{}")
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  appVersion AppVersion @relation(fields: [appVersionId], references: [id])
  actor      User?      @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([appVersionId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  appVersionId String   @default("legacy")
  adminUserId  String
  action       String
  targetType   String
  targetId     String?
  beforeValue  Json?
  afterValue   Json?
  createdAt    DateTime @default(now())

  appVersion AppVersion @relation(fields: [appVersionId], references: [id])
  adminUser  User       @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([appVersionId, createdAt])
}
