{
  "name": "teamaking-desktop",
  "version": "0.1.0",
  "description": "Electron desktop shell for the TEAMAKING website.",
  "author": "TEAMAKING",
  "private": true,
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "npm run desktop:build",
    "start": "next start",
    "desktop:dev": "electron .",
    "desktop:build": "node desktop/prepare-dist.mjs",
    "dist:mac": "npm run desktop:build && electron-builder --mac dmg",
    "dist:win": "npm run desktop:build && electron-builder --win nsis --x64",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate",
    "seed": "tsx prisma/seed.ts",
    "data:cleanup-demo": "tsx scripts/cleanup-demo-data.ts",
    "admin:list": "tsx scripts/admin-users.ts list",
    "admin:create": "tsx scripts/admin-users.ts create",
    "admin:reset-password": "tsx scripts/admin-users.ts reset",
    "test": "vitest run",
    "test:e2e": "env -u FORCE_COLOR -u NO_COLOR playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@prisma/client": "^6.19.3",
    "clsx": "2.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "0.468.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.6",
    "openai": "^6.39.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "prisma": "^6.19.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "read-excel-file": "^9.0.10",
    "remark-gfm": "^4.0.1",
    "tencentcloud-sdk-nodejs-ses": "^4.1.222",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.19.19",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "postcss": "^8.5.15"
  },
  "build": {
    "appId": "org.teamingapp.teamaking.desktop",
    "productName": "TEAMAKING Desktop",
    "directories": {
      "output": "release",
      "buildResources": "desktop/build"
    },
    "files": [
      "package.json",
      "desktop/main.cjs",
      "desktop/preload.cjs",
      "desktop/offline.html",
      "!node_modules/**/*",
      "!**/node_modules/**/*"
    ],
    "asar": true,
    "npmRebuild": false,
    "extraMetadata": {
      "dependencies": {}
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
